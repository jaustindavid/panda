# Standard exclusions — safe defaults for any project hatched from
# paralarva. Owner can extend at any time.

# Dependencies + build artifacts
node_modules/
dist/
build/
coverage/

# Local environment files (never committed)
.env.local
.env.*.local
.env.development
.env.production

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS noise
.DS_Store
.vscode/
.idea/
*.swp

# Firebase / GCP local artifacts (if Firebase is the stack)
.firebase/
firebase-debug.log

# ── Load-bearing for the cuttlefish/nautilus working model ──
# Per-machine Claude Code config. Contains the worktree.bgIsolation
# setting that enables cuttlefish to edit the main tree directly
# (vs. an isolated temporary worktree). See the .claude/ folder's
# settings.local.json for details. Never committed — each developer
# / machine sets their own.
.claude/settings.local.json
