# Copy to .env.local (gitignored) and fill the blanks from the values
# captured during M1 (dispatch/M1-g-outputs.md, also gitignored).
#
# ⚠️ AUTH DOMAIN RAKE: VITE_FIREBASE_AUTH_DOMAIN must be the HOSTING domain
# (<project-id>.web.app), NOT the Firebase-emitted <project-id>.firebaseapp.com
# — the default breaks sign-in silently on Chrome (storage partitioning).
# measurementId is intentionally absent (no analytics, PRD §1.4).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=panda-bamboo-lane.web.app
VITE_FIREBASE_PROJECT_ID=panda-bamboo-lane
VITE_FIREBASE_STORAGE_BUCKET=panda-bamboo-lane.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_GOOGLE_MAPS_API_KEY=
