rules_version = '2';

// panda Firestore security rules. Mirrors the PRD §6 access table 1:1.
// v1 circle membership is HARDCODED here (PRD §11.2 Q4) — there is no
// Membership collection. Adding/removing a member = edit isMember() below
// AND src/lib/allowlist.ts, then redeploy.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // The circle allowlist. KEEP IN SYNC with src/lib/allowlist.ts.
    // email_verified guards against unverified-email impersonation.
    function isMember() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'austindavid@gmail.com',
          'melissapdavid@gmail.com',
          'drewdavid05@gmail.com',
          'jacobhdavid07@gmail.com'
        ];
    }

    // User — read: members; write: self (profile only).
    match /users/{uid} {
      allow read: if isMember();
      allow write: if isMember() && request.auth.uid == uid;
    }

    // Note — read: members; create: any member (author = self);
    // update/delete: author.
    match /notes/{noteId} {
      allow read: if isMember();
      allow create: if isMember()
        && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isMember()
        && resource.data.authorUid == request.auth.uid;
    }

    // Visit — read: members; create: any member (for self); delete: creator.
    // (Edits are rare and disallowed in v1.)
    match /visits/{visitId} {
      allow read: if isMember();
      allow create: if isMember()
        && request.resource.data.byUid == request.auth.uid;
      allow delete: if isMember() && resource.data.byUid == request.auth.uid;
    }

    // PlaceOverride — read: members; create/update/delete: ANY member
    // (collective circle knowledge, not author-locked). Doc id = placeId.
    match /overrides/{placeId} {
      allow read: if isMember();
      allow write: if isMember();
    }

    // NoGo — circle-shared per-place block. read/create/delete: any member
    // (collective; not author-locked). Doc id = placeId.
    match /nogos/{placeId} {
      allow read: if isMember();
      allow create, delete: if isMember();
    }

    // SavedPlace (favorite) — circle-shared per-place include. read/write:
    // any member. Doc id = placeId. Carries a name/hours snapshot (the
    // accepted favorites-only caching step-over, PRD §11.2 Q3c).
    match /savedPlaces/{placeId} {
      allow read: if isMember();
      allow write: if isMember();
    }

    // Feedback — app feedback for later review. read: members (circle-wide,
    // owner's choice); create: any member (author = self); immutable, so no
    // update/delete.
    match /feedback/{feedbackId} {
      allow read: if isMember();
      allow create: if isMember()
        && request.resource.data.authorUid == request.auth.uid;
    }

    // BlockedBrand — circle-shared chain/brand block (e.g. "Walmart"), matched
    // client-side as a name substring everywhere (PRD §11.2 Q11 follow-on).
    // read/create/delete: any member (collective; not author-locked). Doc id
    // = a normalized (lowercased) name, so re-blocking overwrites, not dupes.
    match /blockedBrands/{brandId} {
      allow read: if isMember();
      allow create, delete: if isMember();
    }

    // Everything else is denied. Unmatched paths default-deny; this is the
    // explicit baseline.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
